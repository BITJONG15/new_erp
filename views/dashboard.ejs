        async function loadEmploiTemps() {
            try {
                let url = '';
                if (role === 'professeur') {
                    url = '/api/emploi-temps/professeur/me';
                } else if (role === 'etudiant') {
                    const profileRes = await fetch('/api/auth/profile', fetchOptions);
                    const profile = await profileRes.json();
                    if (profile.data && profile.data.etudiant) {
                        url = `/api/emploi-temps/filiere/${profile.data.etudiant.filiere_id}`;
                    }
                }
                
                if (!url) return;

                const response = await fetch(url, fetchOptions);
                const result = await response.json();
                const tbody = document.getElementById('table-emploi-temps');
                
                if (response.ok && result.data.length > 0) {
                    const jours = ['Lundi', 'Mardi', 'Mercredi', 'Jeudi', 'Vendredi', 'Samedi'];
                    const heures = ['08:00', '10:00', '13:00', '15:00'];
                    const heuresFin = ['10:00', '12:00', '15:00', '17:00'];
                    
                    let html = '';
                    heures.forEach((heure, index) => {
                        html += `<tr><td><strong>${heure} - ${heuresFin[index]}</strong></td>`;
                        jours.forEach(jour => {
                            const seance = result.data.find(s => s.jour_semaine === jour && s.heure_debut.startsWith(heure));
                            if (seance) {
                                html += `<td class="bg-light">
                                    <strong>${seance.matiere ? seance.matiere.nom : 'N/A'}</strong><br>
                                    <small>${role === 'professeur' ? (seance.matiere && seance.matiere.filiere ? seance.matiere.filiere.nom : '') : (seance.matiere && seance.matiere.professeur && seance.matiere.professeur.user ? seance.matiere.professeur.user.nom_complet : '')}</small><br>
                                    <span class="badge bg-secondary">${seance.salle}</span>
                                </td>`;
                            } else {
                                html += `<td></td>`;
                            }
                        });
                        html += `</tr>`;
                    });
                    tbody.innerHTML = html;
                } else {
                    tbody.innerHTML = '<tr><td colspan="7" class="text-muted py-5 text-center">Aucun cours programmé cette semaine</td></tr>';
                }
            } catch (error) { console.error(error); }
        }

        // --- FONCTIONS DE CRÉATION (ADMIN) ---

        function showAlert(message, type = 'success') {
            const alertHtml = `<div class="alert alert-${type} alert-dismissible fade show" role="alert">
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>`;
            document.getElementById('alert-container').innerHTML = alertHtml;
            setTimeout(() => {
                document.getElementById('alert-container').innerHTML = '';
            }, 5000);
        }

        async function openModalEtudiant() {
            // Charger les filières pour le select
            const res = await fetch('/api/filieres', fetchOptions);
            const filieres = await res.json();
            const select = document.getElementById('select-filiere-etudiant');
            if (res.ok && filieres.data) {
                select.innerHTML = '<option value="">Choisir une filière...</option>' + 
                    filieres.data.map(f => `<option value="${f.id}">${f.nom}</option>`).join('');
            }
            new bootstrap.Modal(document.getElementById('modalEtudiant')).show();
        }

        async function saveEtudiant() {
            const form = document.getElementById('formEtudiant');
            const formData = new FormData(form);
            const data = Object.fromEntries(formData.entries());
            
            try {
                const res = await fetch('/api/etudiants', {
                    method: 'POST',
                    headers: fetchOptions.headers,
                    body: JSON.stringify(data)
                });
                const result = await res.json();
                if (res.ok) {
                    bootstrap.Modal.getInstance(document.getElementById('modalEtudiant')).hide();
                    form.reset();
                    showAlert('Étudiant ajouté avec succès');
                    loadEtudiants();
                    loadDashboardStats();
                } else {
                    showAlert(result.message || 'Erreur lors de l\'ajout', 'danger');
                }
            } catch (error) { console.error(error); showAlert('Erreur serveur', 'danger'); }
        }

