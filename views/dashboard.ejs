        function downloadReleve() {
            alert("Génération du relevé PDF en cours... (Cette fonctionnalité nécessite que l'étudiant ait des notes enregistrées)");
            // Implémentation réelle : window.open(`/api/notes/etudiant/${etudiantId}/releve`, '_blank');
