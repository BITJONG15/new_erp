        async function openModalMatiere() {
            // Charger les filières et profs
            const resF = await fetch('/api/filieres', fetchOptions);
            const filieres = await resF.json();
            const selectF = document.getElementById('select-filiere-matiere');
            if (resF.ok && filieres.data) {
                selectF.innerHTML = '<option value="">Choisir une filière...</option>' + 
                    filieres.data.map(f => `<option value="${f.id}">${f.nom}</option>`).join('');
            }

            const resP = await fetch('/api/professeurs', fetchOptions);
            const profs = await resP.json();
            const selectP = document.getElementById('select-prof-matiere');
            if (resP.ok && profs.data) {
                selectP.innerHTML = '<option value="">Aucun</option>' + 
                    profs.data.map(p => `<option value="${p.id}">${p.user ? p.user.nom_complet : 'Prof #'+p.id}</option>`).join('');
            }

            new bootstrap.Modal(document.getElementById('modalMatiere')).show();
        }

        async function saveMatiere() {
            const form = document.getElementById('formMatiere');
            const formData = new FormData(form);
            const data = Object.fromEntries(formData.entries());
            if(!data.professeur_id) delete data.professeur_id;
            
            try {
                const res = await fetch('/api/matieres', {
                    method: 'POST',
                    headers: fetchOptions.headers,
                    body: JSON.stringify(data)
                });
                const result = await res.json();
                if (res.ok) {
                    bootstrap.Modal.getInstance(document.getElementById('modalMatiere')).hide();
                    form.reset();
                    showAlert('Matière ajoutée avec succès');
                    // On recharge les filières car les matières y sont liées dans l'affichage (à améliorer)
                    loadFilieres(); 
                } else {
                    showAlert(result.message || 'Erreur lors de l\'ajout', 'danger');
                }
            } catch (error) { console.error(error); showAlert('Erreur serveur', 'danger'); }
        }

        async function openModalPaiement() {
            // Charger les étudiants
            const res = await fetch('/api/etudiants', fetchOptions);
