        async function loadMatieresProf() {
            try {
                const response = await fetch('/api/matieres/professeur/me', fetchOptions);
                const result = await response.json();
                const select = document.getElementById('select-matiere-prof');
                
                if (response.ok && result.data.length > 0) {
                    select.innerHTML = '<option value="">Choisir une matière...</option>' + 
                        result.data.map(m => `<option value="${m.id}">${m.nom} (${m.filiere ? m.filiere.nom : 'N/A'})</option>`).join('');
