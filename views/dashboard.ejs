                select.innerHTML = '<option value="">Choisir un étudiant...</option>' + 
                    etudiants.data.map(e => `<option value="${e.id}">${e.matricule} - ${e.user ? e.user.nom_complet : ''}</option>`).join('');
            }
            new bootstrap.Modal(document.getElementById('modalPaiement')).show();
        }

        async function savePaiement() {
            const form = document.getElementById('formPaiement');
            const formData = new FormData(form);
            const data = Object.fromEntries(formData.entries());
            
            try {
                const res = await fetch('/api/paiements', {
                    method: 'POST',
