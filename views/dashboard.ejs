        async function loadEtudiantsForNotes() {
            const matiereId = document.getElementById('select-matiere-prof').value;
            if (!matiereId) return alert('Veuillez sélectionner une matière');
            
            try {
                const response = await fetch(`/api/notes/matiere/${matiereId}/etudiants`, fetchOptions);
                const result = await response.json();
                const tbody = document.getElementById('table-saisie-notes');
                
                if (response.ok) {
                    document.getElementById('card-saisie-notes').classList.remove('d-none');
                    if (result.data.length > 0) {
                        tbody.innerHTML = result.data.map(e => {
                            const note = e.notes && e.notes.length > 0 ? e.notes[0] : { note_cc: '', note_examen: '' };
                            return `
                                <tr>
                                    <td>${e.user ? e.user.nom_complet : 'N/A'} (${e.matricule})</td>
                                    <td><input type="number" id="cc-${e.id}" class="form-control form-control-sm" value="${note.note_cc !== null && note.note_cc !== undefined ? note.note_cc : ''}" max="20" step="0.25"></td>
                                    <td><input type="number" id="exam-${e.id}" class="form-control form-control-sm" value="${note.note_examen !== null && note.note_examen !== undefined ? note.note_examen : ''}" max="20" step="0.25"></td>
                                    <td><button class="btn btn-sm btn-success" onclick="saveNote(${e.id}, ${matiereId})">Enregistrer</button></td>
                                </tr>
                            `;
                        }).join('');
                    } else {
                        tbody.innerHTML = '<tr><td colspan="4" class="text-center">Aucun étudiant dans cette filière.</td></tr>';
                    }
                }
            } catch (error) { console.error(error); }
        }

        async function saveNote(etudiantId, matiereId) {
            const note_cc = document.getElementById(`cc-${etudiantId}`).value;
            const note_examen = document.getElementById(`exam-${etudiantId}`).value;
            
            try {
                const response = await fetch('/api/notes/saisie', {
                    method: 'POST',
                    headers: fetchOptions.headers,
                    body: JSON.stringify({
                        etudiant_id: etudiantId,
                        matiere_id: matiereId,
                        note_cc: note_cc ? parseFloat(note_cc) : null,
                        note_examen: note_examen ? parseFloat(note_examen) : null,
                        session: 'normale',
                        annee_academique: new Date().getFullYear() + '-' + (new Date().getFullYear() + 1)
                    })
                });
                
                const result = await response.json();
                if (response.ok) {
                    showAlert('Note enregistrée avec succès', 'success');
                } else {
                    showAlert(result.message || 'Erreur lors de l\\'enregistrement', 'danger');
                }
            } catch (error) {
                console.error(error);
                showAlert('Erreur serveur', 'danger');
            }
        }

        async function loadMesNotes() {
            try {
                // Pour l'étudiant connecté, on récupère son profil pour avoir son ID étudiant
                const profileRes = await fetch('/api/auth/profile', fetchOptions);
                const profile = await profileRes.json();
                
                if (profile.data && profile.data.etudiant) {
                    const etudiantId = profile.data.etudiant.id;
                    const response = await fetch(`/api/notes/etudiant/${etudiantId}`, fetchOptions);
                    const result = await response.json();
                    
                    const tbody = document.getElementById('table-mes-notes');
                    
                    if (response.ok && result.data.length > 0) {
                        tbody.innerHTML = result.data.map(n => `
                            <tr>
                                <td><strong>${n.matiere ? n.matiere.nom : 'N/A'}</strong></td>
                                <td>${n.matiere ? n.matiere.coefficient : '-'}</td>
                                <td>${n.note_cc !== null ? n.note_cc : '-'}</td>
                                <td>${n.note_examen !== null ? n.note_examen : '-'}</td>
                                <td><span class="badge ${n.note_finale >= 10 ? 'bg-success' : 'bg-danger'} fs-6">${n.note_finale !== null ? n.note_finale : '-'}</span></td>
                            </tr>
                        `).join('');
                    } else {
                        tbody.innerHTML = '<tr><td colspan="5" class="text-center">Aucune note disponible pour le moment.</td></tr>';
                    }
                }
            } catch (error) { console.error(error); }
        }

        async function loadMesPaiements() {
            try {
                const profileRes = await fetch('/api/auth/profile', fetchOptions);
                const profile = await profileRes.json();
                
                if (profile.data && profile.data.etudiant) {
                    const etudiantId = profile.data.etudiant.id;
