                                <td><strong>${p.reference}</strong></td>
                                <td>${p.commentaire || '-'}</td>
                                <td><span class="text-success fw-bold">${p.montant} FCFA</span></td>
                                <td>
                                    <a href="/api/paiements/${p.id}/recu" target="_blank" class="btn btn-sm btn-outline-primary">Télécharger</a>
